<!DOCTYPE html>
<html>
<head>
    <title>Cyber Defense</title>
    <style>
        body { background: #000; color: #0f0; text-align: center; font-family: 'Courier New', monospace; }
        #box { width: 300px; height: 300px; border: 2px solid #0f0; margin: auto; position: relative; overflow: hidden; }
        .virus { width: 30px; height: 30px; background: red; position: absolute; cursor: crosshair; }
    </style>
</head>
<body>
    <h1>CYBER DEFENSE OS</h1>
    <p>Clique nos vírus vermelhos para deletar!</p>
    <div id="box"></div>
    <script>
        const box = document.getElementById('box');
        setInterval(() => {
            const v = document.createElement('div');
            v.className = 'virus';
            v.style.top = Math.random() * 270 + 'px';
            v.style.left = Math.random() * 270 + 'px';
            v.onclick = () => v.remove();
            box.appendChild(v);
            setTimeout(() => v.remove(), 2000);
        }, 1000);
    </script>
</body>
</html>
